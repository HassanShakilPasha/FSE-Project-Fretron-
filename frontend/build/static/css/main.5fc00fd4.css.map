

.navbar {
  display: flex;
  align-items: center;
  justify-content: space-between;  
  padding: 15px 50px;
  background-color: white;
  font-family: sans-serif;
}
 

.logo h2 {
  color: #1698ee;
  margin: 0;
  font-size: 24px;
  font-weight: bold;
}

.logo a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8px 14px;
  border-radius: 8px;
  border: 1px solid #b9d5ef;
  background: #eef7ff;
  text-decoration: none;
}

.logo a:hover {
  background: #e2f1ff;
}


.nav-links {
  list-style: none;
  display: flex;
  gap: 12px;
  margin: 0;
  padding: 0;
  align-items: center;
}

.nav-links a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8px 16px;
  border-radius: 6px;
  background-color: #123b66;
  border: none;
  cursor: pointer;
  text-decoration: none;
  color: white;
  font-weight: 500;
  transition: background-color 0.3s;
}

.nav-links a:hover {
  background-color: #333366;
}


.nav-right {
  display: flex;
  align-items: center;
  gap: 20px;
}

.nav-right {
  text-decoration: none;
  color: gray;
  font-weight: 500;
}

.nav-right span {
  white-space: nowrap;
  font-size: 14px;
}

.nav-right .login:hover {
  color: #1698ee;
}

.nav-right .btn {
  background-color: #00001a;
  color: white;
  padding: 8px 16px;
  border-radius: 6px;
  text-decoration: none;
  font-weight: 500;
  transition: background-color 0.3s;
  border: none;
  cursor: pointer;
}

.nav-right .btn:hover {
  background-color: #c62828;
}