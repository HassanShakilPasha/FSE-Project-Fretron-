    font-size:16px;
    border:1px solid #ccc;
    border-radius:5px;
    margin:0;
    width:100%;
    height:60px;
    background-color:lightgray;
}



.CreateRoute .buttons{
    display:flex;
    gap:20px;
    margin:20px;
}



#createRouteBtn{
    width:700px;
    padding:14px;
    background:black;
    color:white;
    border:none;
    border-radius:8px;
    font-size:16px;
    cursor:pointer;
}



#cancelBtn{
    padding:14px 25px;
    border-radius:8px;
    border:1px solid gray;
    margin-left: 20px;
    background:white;
    font-size:16px;
    cursor:pointer;
}


#Forgot
{
    margin-left: 20px;
    text-decoration: none;
}

.formStatus {
    margin: 8px 20px;
    font-size: 14px;
}

.formError {
    color: #b91c1c;
}

.formSuccess {
    color: #15803d;
}


