.CreateRoute{
    width:100%;
    min-height:100vh;
    max-width: 1240px;
    margin: 0 auto;
    padding: 20px 20px 36px;
    box-sizing: border-box;
}

.CreateRoute .CreateRouteContainer {
    background: #ffffff;
    border-radius: 14px;
    box-shadow: 0 10px 26px rgba(16, 24, 40, 0.08);
    padding: 20px 12px 20px;
    max-width: 1080px;
    margin: 0 auto;
}


.CreateRoute .row{
    display:flex;
    gap:40px;
    margin-bottom:20px;
    justify-content: center;
}

.CreateRoute .row > div {
    width: 500px;
}

.CreateRoute .full {
    max-width: 1040px;
    margin: 0 auto 20px;
}



.CreateRoute .Initial h1{
    margin-left:0;
    margin-top:20px;
    margin-bottom:0;
    font-weight:bolder;
    font-size:40px;
    text-align:center;
}

.CreateRoute .Initial p{
    margin-top:5px;
    margin-left:0;
    color:dimgray;
    font-size:16px;
    text-align:center;
}

.CreateRoute .Initial {
    text-align: center;
}



.CreateRoute .Details{
    width:100%;
    max-width:100%;
    margin-left:0;
    margin-top:16px;
    border:none;
    border-radius:10px;
    padding-bottom:20px;
    background: #f8fbff;

    margin-bottom: 0;
}

.CreateRoute .Details h4{
    font-weight:normal;
    margin-left:0;
    font-size:20px;
    margin-bottom:10px;
    margin-top:10px;
    text-align:center;
}



.CreateRoute .left{
    margin:20px 20px 0;
}



#label-Origin
{
    display:block;
    font-size:16px;
    margin-left:0;
    margin-bottom:8px;
    font-weight:normal;
    text-align:center;
} 


