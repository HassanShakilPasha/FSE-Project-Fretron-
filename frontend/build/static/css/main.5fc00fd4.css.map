.myBookingsPage {
    width: 100%;
    margin: 0 auto;
    padding: 20px 30px 40px;
    box-sizing: border-box;
}

.myBookingsPage .myBookingsContainer {
    background: #ffffff;
    border-radius: 14px;
    box-shadow: 0 10px 26px rgba(16, 24, 40, 0.08);
    padding: 24px 20px 28px;
}

.myBookingsPage .top p{
    color: #4a5565
}

.myBookingsPage .top h1,
.myBookingsPage .top p {
    text-align: center;
}


.myBookingsPage .grid1
{
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    margin-top: 50px;
    border: none;
    
}


.myBookingsPage .box
{
    width: 240px;
    height: 90px;
}


.myBookingsPage .b1
{
    color: #4a5565;
    
    margin-left: 20px;
    margin-bottom: 0;
}

.myBookingsPage .vari
{
    padding: 0;
    margin-top: 0px 0 0 0;
    color:black;
    font-size: 24px;
    font-weight: bold;
}

.myBookingsPage .vari p
{
    margin: 0px 0 0 0;

}


.myBookingsPage .vari1
{
    padding: 0;
    margin-top: 0px;
    color: black;
    font-size: 24px;
    font-weight: bold;
}

.myBookingsPage .vari1 p
{
    margin: 0px 0 0 0;

}

.myBookingsPage .quick
{
    margin-top: 50px;
    border: none;
    border-radius: 8px;
    width: 100%;
    box-sizing: border-box;
    background: #f8fbff;
}

.myBookingsPage .quick p
{
    color: black;
    font-size: 16px;
    font-weight: 600;
    margin-left: 20px;
}


.myBookingsPage .qgrid
{
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    margin-top: 20px;
    gap: 20px;
    margin-left: 20px;
    margin-bottom: 20px;
    padding-right: 20px;
}

.myBookingsPage .quickNavBtn {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    padding: 1.1em 2em;
    border: 2px solid #fff;
    font-size: 15px;
    color: #131313;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: all 0.3s;
    border-radius: 12px;
    background-color: #ecd448;
    font-weight: bolder;
    box-shadow: 0 2px 0 2px #000;
    min-height: 80px;
    box-sizing: border-box;
}

.myBookingsPage .quickNavBtn:before {
    content: "";
    position: absolute;
    width: 100px;
    height: 120%;
    background-color: #ff6700;
    top: 50%;
    transform: skewX(30deg) translate(-150%, -50%);
    transition: all 0.5s;
}

.myBookingsPage .quickNavBtn:hover {
    background-color: #4cc9f0;
    color: #fff;
    box-shadow: 0 2px 0 2px #0d3b66;
}

.myBookingsPage .quickNavBtn:hover::before {
    transform: skewX(30deg) translate(150%, -50%);
    transition-delay: 0.1s;
}

.myBookingsPage .quickNavBtn:active {
    transform: scale(0.9);
}


.myBookingsPage .view{
    display:flex;
    gap:30px;
    margin-top:40px;
}

.myBookingsPage .panel{
    flex:1;
    border:none;
    border-radius:12px;
    padding:20px;
    background: #f8fbff;
}

.myBookingsPage .panelHeader{
    display:flex;
    justify-content:space-between;
    margin-bottom:20px;
}

.myBookingsPage .title{
    font-weight:600;
    font-size:18px;
}

.myBookingsPage .viewAll{
    color:gray;
    cursor:pointer;
}

.myBookingsPage .card{
    border:none;
    border-radius:10px;
    padding:15px;
    background: #f9fcff;
}

.myBookingsPage .cardTop{
    display:flex;
    justify-content:space-between;
    margin-bottom:10px;
}

.myBookingsPage .tag{
    background:#f0f0f0;
    padding:4px 10px;
    border-radius:6px;
}

.myBookingsPage .status{
    background:black;
    color:white;
    padding:3px 10px;
    border-radius:6px;
    font-size:12px;
}

.myBookingsPage .route{
    margin:10px 0;
}

.myBookingsPage .cardBottom{
    display:flex;
    justify-content:space-between;
}

.myBookingsPage .price{
    color:#2a6df4;
    font-weight:600;
}