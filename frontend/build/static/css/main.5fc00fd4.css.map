#Origin
{
    display:block;
    padding:10px;
    font-size:16px;
    border:1px solid #ccc;
    border-radius:5px;
    margin:0;
    width:100%;
    height:42px;
    box-sizing:border-box;
    background-color:lightgray;
    color:black;
}


#Destination
{
    display:block;
    padding:10px;
    font-size:16px;
    border:1px solid #ccc;
    border-radius:5px;
    margin:0;
    width:100%;
    height:42px;
    box-sizing:border-box;
    background-color:lightgray;
    color:black;
}

.CreateRoute .cityOtherInput {
    display: block;
    padding: 10px;
    font-size: 16px;
    border: 1px solid #ccc;
    border-radius: 5px;
    margin: 10px 0 0;
    width: 100%;
    height: 42px;
    box-sizing: border-box;
    background-color: lightgray;
    color: black;
}
