.main
{
    margin-left: 50px;
}

.top{
    margin-left: 0;
}
.top p{
    color: #4a5565
}


.grid1
{
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    margin-top: 50px;
    border: none;
    
}


.box
{
    width: 240px;
    height: 90px;
}


.b1
{
    color: #4a5565;
    
    margin-left: 20px;
    margin-bottom: 0;
}

.vari
{
    padding: 0;
    margin-top: 0px 0 0 0;
    color:black;
    font-size: 24px;
    font-weight: bold;
}

.vari p
{
    margin: 0px 0 0 0;

}


.vari1
{
    padding: 0;
    margin-top: 0px;
    color: black;
    font-size: 24px;
    font-weight: bold;
}

.vari1 p
{
    margin: 0px 0 0 0;

}

.quick
{
    margin-top: 50px;
    border: 1px solid  #4a5565;
    border-radius: 8px;
    width: 1380px
}

.quick p
{
    color: black;
    font-size: 16px;
    font-weight: 600;
    margin-left: 20px;
}


.qgrid
{
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    margin-top: 20px;
    gap: 20px;
    margin-left: 20px;
    margin-bottom: 20px;
    padding-right: 20px;
}

#b
{
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px;
    font-size: 14px;
    height: 80px;
    background-color: white;
    border-radius: 8px;
    border: 1px solid #4a5565;
    text-decoration: none;
    color: black;
}

#b:hover
{
    background-color: #f5f5f5;
    cursor: pointer;
}


.view{
    display:flex;
    gap:30px;
    margin-top:40px;
}

.panel{
    flex:1;
    border:1px solid #ddd;
    border-radius:12px;
    padding:20px;
}

.panelHeader{
    display:flex;
    justify-content:space-between;
    margin-bottom:20px;
}

.title{
    font-weight:600;
    font-size:18px;
}

.viewAll{
    color:gray;
    cursor:pointer;
}

.card{
    border:1px solid #ddd;
    border-radius:10px;
    padding:15px;
}

.cardTop{
    display:flex;
    justify-content:space-between;
    margin-bottom:10px;
}

.tag{
    background:#f0f0f0;
    padding:4px 10px;
    border-radius:6px;
}

.status{
    background:black;
    color:white;
    padding:3px 10px;
    border-radius:6px;
    font-size:12px;
}

.route{
    margin:10px 0;
}

.cardBottom{
    display:flex;
    justify-content:space-between;
}

.price{
    color:#2a6df4;
    font-weight:600;
}