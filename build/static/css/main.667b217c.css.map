.top 
{
    margin-left: 50px;
}

.top h1
{
    margin-top: 30px;
    margin-bottom: 0px;
    padding-bottom: 0px;
}

.top p{
    margin-top: 9px;
    color: #4a5565;
}

.Search
{
    margin-left: 50px;
    margin-top: 50px;
    border-radius: 8px;
    width: 1300px;
    padding: 20px;
    box-shadow: 0px 4px 10px rgba(0,0,0,0.2);
}


.Search h3
{
    font-size: 20px;
    margin-left: 0px;
    margin-top: 0px;
}

.grid 
{
    display: grid;
    grid-template-columns: 1.5fr 1.5fr 1fr auto; /* 4 items in one row */
    gap: 20px;
    align-items: end;
    margin-top: 20px;
}

/* Origin */
.Origin
{
    display: flex;
    flex-direction: column; 
    gap: 5px;
    width:350px;
}

#label-origin
{
    font-size:16px;
    font-weight: bold;
}

#origin
{
    padding: 10px 12px;
    font-size:16px;
    border:1px solid #ccc;
    border-radius:5px;
    width:100%;
    background-color:lightgray;
    color:black;
}

/* Destination */
.Destination
{
    display: flex;
    flex-direction: column; 
    gap: 5px;
    width:350px;
}

#label-destination
{
    font-size:16px;
    font-weight: bold;
}

#destination
{
    padding: 10px 12px;
    font-size:16px;
    border:1px solid #ccc;
    border-radius:5px;
    width:100%;
    background-color:lightgray;
    color:black;
}

/* Vehicle */
.Vehicle
{
    display: flex;
    flex-direction: column; 
    gap: 5px;
    width:350px;
    margin-left: 0px;
    margin-right: 20px;
}

#label-vehicle
{
    font-size:16px;
    font-weight:bold;
}

#vehicle 
{
    font-size: 16px;
    border: 1px solid #ccc;
    border-radius: 5px;
    width: 100%;  
    height: 38px;
    background-color: lightgray;
    color: black;
}

.Button 
{
    display: flex;
    align-items: end;
}

#Search 
{
    width: 100%;
    padding: 10px 20px;
    font-size: 16px;
    margin-left: 10px;
    border: none;
    border-radius: 5px;
    background: black;
    color: white;
    cursor: pointer;
}

.Available
{
    margin-left: 50px;
    color: #4a5565;
}

.grid2
{
    margin-top: 20px;
}

.row
{
    display: grid;
    grid-template-columns: 1fr 1fr 1fr; 
    gap: 20px;
    margin-top: 20px;
}


.box
{
    border: 1px solid #ccc;
    border-radius: 12px;
    padding: 0 10px 20px;
    background-color: white;
    width: 350px;
}

/* This is the start*/

.company
{
    margin-top: 0px;
    padding: 0px;
    margin: 0;
}

.price
{
    font-size: 20px;
    color: blue;
    font-weight: bold;
}

.perton
{
    font-size: 16px;
    font-weight: bold;
    color: #4a5565;
}

.vehicle1
{
    text-align: center;
    border-radius: 8px;
    background-color: #4a5565;
    color: white;
    width: 130px;
}

.or
{
    color: black;
    font-weight: 500;
}

.des
{
    color: black;
    font-weight: 500;
}


.details
{
    color: black;
    font-weight: 350;
}

.book
{
    text-align: center;
    width: 280px;
    color: white;
    background-color: black;
    height: 30px;
    border: none;
    border-radius: 8px;
}